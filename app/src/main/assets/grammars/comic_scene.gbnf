# Memento 漫剧场景 GBNF grammar —— "三刀流"事前约束
#
# 设计心法：永远不要相信 LLM 的理解力，只用它的填空能力。
# 本 grammar 在采样阶段强制约束输出结构，模型物理上无法生成非法 JSON。
#
# 三刀流：
#   第一刀：layout 用 enum 锁死取值
#   第二刀：assetRef 受控词汇表（只能从 asset_registry 选）
#   第三刀：timeline 用 beats 简化结构（0.8B 友好），复杂时序交渲染器推导
#
# 注意：assetRef 的合法集合会随资源库扩展而变化，
#       本文件只约束结构，具体 asset 字符串不做白名单（由 SceneValidator 兜底校验）。

root   ::= "{" ws "\"layout\":" ws layout ws "," ws
               "\"characters\":" ws characters ws "," ws
               "\"beats\":" ws beats ws "," ws
               "\"dialogue\":" ws dialogue ws
          "}"

# ── 第一刀：layout enum 锁死 ──
layout ::= "\"fullscreen\"" | "\"split\"" | "\"overlay\""

# ── characters 数组 ──
characters ::= "[" ws char? (ws "," ws char)* ws "]"

char  ::= "{" ws
              "\"id\":" ws string ws "," ws
              "\"name\":" ws string ws "," ws
              "\"assetRef\":" ws string ws "," ws
              "\"expression\":" ws string ws "," ws
              "\"transform\":" ws transform ws
          "}"

transform ::= "{" ws
                  "\"x\":" ws number ws "," ws
                  "\"y\":" ws number ws "," ws
                  "\"scale\":" ws number ws "," ws
                  "\"rotation\":" ws number ws
              "}"

# ── 第三刀：beats 简化时序（LLM 只写剧本，节奏细节渲染器推导） ──
beats ::= "[" ws beat? (ws "," ws beat)* ws "]"

# beat 类型由 target 字段决定：char_id.expression / dialogue.bubble / scene.transition
beat  ::= "{" ws
              "\"t\":" ws number ws "," ws
              "\"target\":" ws string ws "," ws
              "\"value\":" ws string ws
          "}"

# ── dialogue 气泡 ──
dialogue ::= "{" ws
                 "\"speaker\":" ws string ws "," ws
                 "\"text\":" ws string ws "," ws
                 "\"animation\":" ws animation ws
             "}"

animation ::= "\"pop\"" | "\"fade\"" | "\"typewriter\"" | "\"slide\""

# ── 基础类型 ──
string  ::= "\"" ( [^"\\] | "\\" .)* "\""
number  ::= "-"? ([0-9] | [1-9] [0-9]*) ("." [0-9]+)?
ws      ::= [ \t\n]*
